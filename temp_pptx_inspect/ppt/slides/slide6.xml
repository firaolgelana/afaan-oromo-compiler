<p:sld xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:p="http://schemas.openxmlformats.org/presentationml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><p:cSld><p:spTree><p:nvGrpSpPr><p:cNvPr id="1" name=""/><p:cNvGrpSpPr/><p:nvPr/></p:nvGrpSpPr><p:grpSpPr/><p:sp><p:nvSpPr><p:cNvPr id="2" name="Title 1"/><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph type="title"/></p:nvPr></p:nvSpPr><p:spPr/><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:r><a:t>5. The Compilation Pipeline</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="3" name="Content Placeholder 2"/><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph idx="1"/></p:nvPr></p:nvSpPr><p:spPr/><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:r><a:t>How Afaan Oromoo code becomes executable:</a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:t>1. Lexical Analysis (Scanner): Converts raw text into Tokens.</a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:t>2. Parsing: Builds an Abstract Syntax Tree (AST) representing the program's structure.</a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:t>3. Code Generation (Codegen): Traverses the AST to emit Python 3 source code.</a:t></a:r></a:p><a:p><a:pPr lvl="1"/><a:r><a:t>4. Execution: Runs the generated Python code natively.</a:t></a:r></a:p></p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>