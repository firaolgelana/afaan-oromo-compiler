# math.ao - Testing mathematical operations and built-ins
fuudhu herrega

maxxansi("=== Herrega (Math) ===")

a = -15
b = 25
c = 9

maxxansi("Gatsirrii (abs): " + barruu(gatsirrii(a)))
maxxansi("Guddaa (max): " + barruu(guddaa(a, b)))
maxxansi("Xiqqaa (min): " + barruu(xiqqaa(a, b)))
maxxansi("Ruut (sqrt of 9): " + barruu(ruut(c)))
maxxansi("Pao (3^2): " + barruu(pao(3, 2)))

tar = [1, 2, 3, 4, 5]
maxxansi("Ida'uu (sum of list): " + barruu(ida'uu(tar)))
maxxansi("Naannessi (round 3.6): " + barruu(naannessi(3.6)))
